# ─── LLM Provider ────────────────────────────────────────────────────────────
# Set to "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_DATABASE=financial_rag

# ─── Web Search ───────────────────────────────────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...

# ─── Agent Behaviour ─────────────────────────────────────────────────────────
# Max rows the MySQL agent may return before summarising
MAX_SQL_ROWS=50
# How many web results to fetch
WEB_SEARCH_RESULTS=5
# Temperature for synthesis (0 = deterministic, 1 = creative)
SYNTHESIS_TEMPERATURE=0.2
# Enable streaming responses from FastAPI
ENABLE_STREAMING=true

# ─── Bond RAG (PDF Pipeline) ─────────────────────────────────────────────────
# Paths
BOND_RAG__DB_DIR=db/bond_rag          # ChromaDB + SQLite registry location
BOND_RAG__DATA_DIR=data/pdfs          # Default folder to scan for PDFs

# Chunking
BOND_RAG__CHUNK__CHUNK_SIZE=800       # Characters per chunk
BOND_RAG__CHUNK__OVERLAP_RATIO=0.25  # 25% overlap between chunks

# Embeddings (HuggingFace model — downloads on first run, ~1.3 GB)
BOND_RAG__EMBED__MODEL_NAME=BAAI/bge-large-en-v1.5
BOND_RAG__EMBED__DEVICE=cpu           # or "cuda" / "mps"

# Vector store
BOND_RAG__STORE__COLLECTION_NAME=bond_rag
BOND_RAG__STORE__N_CANDIDATES=20      # Candidates before cross-encoder reranking

# Retriever
BOND_RAG__RETRIEVER__TOP_K=6         # Final chunks passed to synthesiser
BOND_RAG__RETRIEVER__DENSE_WEIGHT=0.65
BOND_RAG__RETRIEVER__RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# OCR (requires tesseract binary: brew install tesseract / apt install tesseract-ocr)
BOND_RAG__OCR__ENABLED=true
BOND_RAG__OCR__DPI=300
BOND_RAG__OCR__LANGUAGE=eng
# BOND_RAG__OCR__TESSERACT_CMD=/usr/local/bin/tesseract  # set if not on PATH
